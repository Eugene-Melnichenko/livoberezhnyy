<%= form_with(model: @service, url: adress_url, local: true) do |form| %>

  <%= render 'layouts/error_messages', object: @service %>

  <div class="form-group ">
    <%= form.label :name %>
    <%= form.text_field :name, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, class: "form-control", rows: "3" %>
  </div>
  <div class="form-group">
    <%= form.label :price %>
    <%= form.text_field :price, class: "form-control" %>
  </div>
  <div class="form-group">      
    <%= form.submit button_text, class: "btn btn-primary btn-block" %>
  </div>
<% end %>