<% if @orders.empty? %>
  <h3 class="text-center text-danger">Ви поки не замовили жодної послуги</h3>
<% elsif %>
  <h3 class="text-center">Послуги які ви замовили</h3>
  <table class="table table-borderless table-hover">
    <thead>
      <tr>
        <th scope="col" class="text-center">Назва/Опис</th>
        <th scope="col">Ціна</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td class="text-justify">
            <li>
              <strong><%= order.service.name %></strong> -
              <em><%= order.service.description %></em>
              <% if !order.message.empty? %>
                <p><strong>Ваше повідомлення</strong>
                - <em><%= order.message %></em>
                </p>
              <% end %>
            </li>
          </td>
          <td>
            <strong><%= order.service.price %></strong>   
          </td>
          <td class="text-center" >
            <%= link_to 'Видалити', users_order_path(order), method: :delete, data: { confirm: 'Ви впевнені?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<h3 class="text-center">Замовити нову послугу</h3>
<%= form_with model: @order, url: users_orders_path, local: true do |form| %>

  <div class="form-group">
    <%= form.label 'Виберіть послугу', class: "font-weight-bold" %>
    <%= form.collection_select :service_id, @services, :id, :name, { include_blank: true }, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label 'Ваше повідомлення', class: "font-weight-bold" %>
    <%= form.text_area :message, class: "form-control", rows: "3" %>
  </div>

  <%= form.submit 'Замовити', class: "btn btn-primary btn-block" %>
  <br>
<% end %>