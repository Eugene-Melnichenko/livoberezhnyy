<hr>
<% if admin_signed_in? %>
  <%= link_to 'Edit', edit_article_path(@article) %>
<% end %>

<p>
  <strong>Title:</strong>
  <%= @article.title %>
</p>

<%= image_tag(@article.image_url.to_s) if @article.image? %>

<p>
  <strong>Text:</strong>
  <%= @article.text %>
</p>
<hr>

<% if user_signed_in? %>
  <h2>Add a comment:</h2>
<% end %>

<%= link_to 'Back', articles_path %>