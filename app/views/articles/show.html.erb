<hr>
<% if user_signed_in? %>
  <%= link_to 'Edit', edit_article_path(@article) %>
<% end %>

<p>
  <strong>Title:</strong>
  <%= @article.title %>
</p>

<p>
  <strong>Text:</strong>
  <%= @article.text %>
</p>
<hr>

<% if !@article.comments.blank? %>
  <h2>Comments</h2>
  <%= render @article.comments %>
<% end %>

<% if user_signed_in? %>
  <h2>Add a comment:</h2>
  <%= render 'comments/form' %>
<% end %>

<%= link_to 'Back', articles_path %>